# ===== 息悦生活环境变量模板 =====
# 用法：cp .env.example .env，然后填入真实值
# .env 已被 .gitignore 忽略，不会提交 Git
# 生产环境所有密码必须使用强随机值

# ----- MySQL -----
MYSQL_ROOT_PASSWORD=change-me-to-strong-password
MYSQL_DATABASE=xiyue_platform

# ----- Redis -----
REDIS_PASSWORD=change-me-to-strong-password

# ----- 后端（阶段1起使用）-----
# JWT 密钥：至少 32 字节，密码学安全随机值
# 生成示例（Linux/macOS）：openssl rand -base64 48
# 禁止使用项目名、手机号或默认短字符串
JWT_SECRET=please-generate-a-32-byte-cryptographic-random-secret
# 管理员初始密码（仅 init.sql 创建 ADMIN 账号时使用）
ADMIN_INIT_PASSWORD=change-me-admin-password
